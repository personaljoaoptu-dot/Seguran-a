          "id": "c5ef944b-4b10-4ff5-b9f0-c5ef54ab6903",
          "name": "PostgreSQL production"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseCode": 200,
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"Cadastro efetuado com sucesso!\",\n  \"data\": {\n    \"usuario_id\": \"{{ $('Insert Usuario').item.json.id }}\",\n    \"empresa_id\": \"{{ $json.id }}\"\n  }\n}",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      },
      "id": "d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f8a",
      "name": "Respond Success",
