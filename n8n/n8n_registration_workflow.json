    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=DELETE FROM activation_tokens WHERE usuario_id IN (\n    SELECT id FROM usuarios \n    WHERE (email = '{{ $('Validate Data').first().json.data.email }}' OR cpf = '{{ $('Validate Data').first().json.data.cpf }}')\n    AND NOT EXISTS (SELECT 1 FROM users WHERE email = usuarios.email)\n);\nDELETE FROM empresas WHERE usuario_id IN (\n    SELECT id FROM usuarios \n    WHERE (email = '{{ $('Validate Data').first().json.data.email }}' OR cpf = '{{ $('Validate Data').first().json.data.cpf }}')\n    AND NOT EXISTS (SELECT 1 FROM users WHERE email = usuarios.email)\n);\nDELETE FROM usuarios \nWHERE (email = '{{ $('Validate Data').first().json.data.email }}' OR cpf = '{{ $('Validate Data').first().json.data.cpf }}')\nAND NOT EXISTS (SELECT 1 FROM users WHERE email = usuarios.email);\n\nSELECT email FROM users WHERE email = '{{ $('Validate Data').first().json.data.email }}' LIMIT 1;",
        "options": {}
      },
